                android:type="linear"
                android:startX="18"
                android:startY="18"
                android:endX="90"
                android:endY="90">

                <!-- Deep Blue -->
                <item
                    android:offset="0.0"
                    android:color="#1E3CFF"/>

                <!-- Vibrant Magenta -->
                <item
                    android:offset="0.55"
                    android:color="#D81BFF"/>

                <!-- Soft Peach -->
                <item
                    android:offset="1.0"
                    android:color="#FFD1B5"/>

            </gradient>
        </aapt:attr>
    </path>

    <!-- White Rounded Play Button -->
    <path
        android:fillColor="#FFFFFF"
